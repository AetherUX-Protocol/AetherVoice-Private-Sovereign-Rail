# --- AETHERVOICE CORE ---
APP_NAME=AetherVoice-Private-Rail
APP_ENV=production

# --- SOLANA CONFIG ---
# Use a high-performance RPC for handling encrypted transaction payloads
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta

# --- UMBRA SDK & ARCIUM MXE ---
# The Arcium Cluster Offset identifies the specific ARX node group executing the encrypted compute
ARCIUM_CLUSTER_OFFSET=your_cluster_offset_here
# The MXE Program ID for Umbra's confidential SPL standard
UMBRA_MXE_PROGRAM_ID=your_umbra_mxe_id_here

# --- QVAC SOVEREIGN AUDIT ---
# Threshold for triggering the Umbra Privacy Rail (0-100)
MIN_TRUST_SCORE=90
QVAC_LOCAL_MODEL_PATH=./models/trade-audit-v1.onnx

# --- MERCHANT COMPLIANCE ---
# The public key used to derive the Viewing Keys for BSA 2026 reports
MERCHANT_MASTER_VIEWING_PUBKEY=your_public_key_here
